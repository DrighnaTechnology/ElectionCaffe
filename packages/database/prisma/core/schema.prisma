// Core Database Schema - ElectionCaffeCore
// This schema contains Super Admin specific tables and global platform configuration
// Database: ElectionCaffeCore

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/core-client"
}

datasource db {
  provider = "postgresql"
  url      = env("CORE_DATABASE_URL")
}

// ==================== SUPER ADMIN & SYSTEM CONFIG ====================

model SystemConfig {
  id          String   @id @default(uuid())
  configKey   String   @unique @map("config_key")
  configValue Json     @map("config_value")
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model SuperAdmin {
  id              String   @id @default(uuid())
  firstName       String   @map("first_name")
  lastName        String?  @map("last_name")
  email           String   @unique
  mobile          String   @unique
  passwordHash    String   @map("password_hash")
  profilePhotoUrl String?  @map("profile_photo_url")
  isActive        Boolean  @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("super_admins")
}

// ==================== FEATURE FLAGS ====================

model FeatureFlag {
  id          String   @id @default(uuid())
  featureKey  String   @unique @map("feature_key")
  featureName String   @map("feature_name")
  description String?
  category    String?
  isGlobal    Boolean  @default(true) @map("is_global")
  defaultEnabled Boolean @default(true) @map("default_enabled")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenantFeatures TenantFeature[]

  @@map("feature_flags")
}

model TenantFeature {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  featureId   String   @map("feature_id")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  settings    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature FeatureFlag @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureId])
  @@map("tenant_features")
}

// ==================== ENUMS ====================

enum TenantType {
  POLITICAL_PARTY
  INDIVIDUAL_CANDIDATE
  ELECTION_MANAGEMENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING
  EXPIRED
  TRIAL
}

enum DatabaseType {
  SHARED
  DEDICATED_PLATFORM
  DEDICATED_EXTERNAL
}

enum DatabaseStatus {
  NOT_CONFIGURED
  PENDING_SETUP
  CONNECTING
  CONNECTED
  CONNECTION_FAILED
  MIGRATING
  READY
  SUSPENDED
}

enum LicensePlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum LicenseStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  EXPIRED
  CANCELLED
  GRACE_PERIOD
}

enum LicenseBillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

enum UsageAlertLevel {
  INFO
  WARNING
  CRITICAL
  EXCEEDED
}

enum AIProviderType {
  OPENAI
  ANTHROPIC
  GOOGLE
  XAI
  CUSTOM
}

enum AIProviderStatus {
  ACTIVE
  INACTIVE
  TESTING
  ERROR
}

enum AIFeatureStatus {
  DRAFT
  TRAINING
  TESTING
  PUBLISHED
  DEPRECATED
  ARCHIVED
}

// ==================== TENANT MANAGEMENT (Core) ====================

model Tenant {
  id                String       @id @default(uuid())
  name              String
  slug              String       @unique
  tenantType        TenantType   @default(INDIVIDUAL_CANDIDATE) @map("tenant_type")
  organizationName  String?      @map("organization_name")
  displayName       String?      @map("display_name")
  tenantUrl         String?      @unique @map("tenant_url")
  customDomain      String?      @unique @map("custom_domain")
  logoUrl           String?      @map("logo_url")
  logoPosition      String?      @default("before") @map("logo_position")
  primaryColor      String?      @map("primary_color") @default("#1890FF")
  secondaryColor    String?      @map("secondary_color")
  faviconUrl        String?      @map("favicon_url")

  // Contact & Location
  contactEmail      String?      @map("contact_email")
  contactPhone      String?      @map("contact_phone")
  address           String?
  state             String?
  country           String?      @default("India")

  // Tenant Admin Identity (cached from tenant DB during creation)
  adminMobile       String?      @map("admin_mobile")
  adminEmail        String?      @map("admin_email")
  adminUserId       String?      @map("admin_user_id")

  // For Political Party tenants
  partyName         String?      @map("party_name")
  partySymbolUrl    String?      @map("party_symbol_url")

  // Database Configuration
  databaseType          DatabaseType   @default(SHARED) @map("database_type")
  databaseStatus        DatabaseStatus @default(NOT_CONFIGURED) @map("database_status")
  databaseHost          String?        @map("database_host")
  databaseName          String?        @map("database_name")
  databaseUser          String?        @map("database_user")
  databasePassword      String?        @map("database_password")
  databasePort          Int?           @map("database_port") @default(5432)
  databaseSSL           Boolean        @default(true) @map("database_ssl")
  databaseConnectionUrl String?        @map("database_connection_url")

  // Database Management
  canTenantEditDb       Boolean        @default(false) @map("can_tenant_edit_db")
  databaseManagedBy     String?        @map("database_managed_by")
  databaseLastCheckedAt DateTime?      @map("database_last_checked_at")
  databaseLastError     String?        @map("database_last_error")
  databaseMigrationVersion String?     @map("database_migration_version")

  // Subscription & Limits
  subscriptionPlan  String?      @map("subscription_plan") @default("free")
  subscriptionId    String?      @map("subscription_id")
  maxVoters         Int          @map("max_voters") @default(10000)
  maxCadres         Int          @map("max_cadres") @default(100)
  maxElections      Int          @map("max_elections") @default(5)
  maxUsers          Int          @map("max_users") @default(50)
  maxConstituencies Int          @map("max_constituencies") @default(1)
  storageQuotaMB    Int          @map("storage_quota_mb") @default(5000)
  storageUsedMB     Int          @map("storage_used_mb") @default(0)

  // Cached usage counts (synced from tenant DBs)
  currentVoterCount    Int       @map("current_voter_count") @default(0)
  currentUserCount     Int       @map("current_user_count") @default(0)
  currentElectionCount Int       @map("current_election_count") @default(0)
  currentCadreCount    Int       @map("current_cadre_count") @default(0)
  countsLastSyncedAt   DateTime? @map("counts_last_synced_at")

  // Status & Dates
  status            TenantStatus @default(PENDING)
  trialEndsAt       DateTime?    @map("trial_ends_at")
  expiresAt         DateTime?    @map("expires_at")
  suspendedAt       DateTime?    @map("suspended_at")
  suspendedReason   String?      @map("suspended_reason")

  // Audit
  createdBy         String?      @map("created_by")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  tenantFeatures    TenantFeature[]
  license           TenantLicense?
  sessions          TenantSession[]
  invitations       Invitation[]
  aiCredits         TenantAICredits?
  aiSubscriptions   TenantAISubscription[]
  aiUsageLogs       AIUsageLog[]
  aiAdminAlerts     AIAdminAlert[]
  newsItems         NewsInformation[]
  actionItems       ActionItem[]
  creditTransactions AICreditTransaction[]

  @@map("tenants")
}

// ==================== LICENSE & BILLING (Core) ====================

model LicensePlan {
  id              String   @id @default(uuid())
  planCode        String?  @unique @map("plan_code")
  planName        String   @unique @map("plan_name")
  planType        LicensePlanType @default(FREE) @map("plan_type")
  description     String?
  monthlyPrice    Decimal  @default(0) @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice     Decimal  @default(0) @map("yearly_price") @db.Decimal(10, 2)
  features        Json     @default("[]")
  limits          Json     @default("{}")

  // User Limits
  maxUsers              Int   @map("max_users") @default(10)
  maxAdminUsers         Int   @map("max_admin_users") @default(2)

  // Session Limits
  maxConcurrentSessions Int   @map("max_concurrent_sessions") @default(5)
  maxSessionsPerUser    Int   @map("max_sessions_per_user") @default(2)
  sessionTimeoutMinutes Int   @map("session_timeout_minutes") @default(30)

  // Data Processing Limits
  maxDataProcessingGB   Float @map("max_data_processing_gb") @default(5.0)
  maxVoters             Int   @map("max_voters") @default(10000)
  maxElections          Int   @map("max_elections") @default(3)
  maxConstituencies     Int   @map("max_constituencies") @default(1)
  maxStorageMB          Int   @map("max_storage_mb") @default(5000)

  // API Limits
  maxApiRequestsPerDay  Int   @map("max_api_requests_per_day") @default(10000)
  maxApiRequestsPerHour Int   @map("max_api_requests_per_hour") @default(1000)

  // Pricing
  basePrice             Float @map("base_price") @default(0)
  pricePerUser          Float? @map("price_per_user")
  pricePerSession       Float? @map("price_per_session")
  pricePerGBProcessed   Float? @map("price_per_gb_processed")
  billingCycle          LicenseBillingCycle @default(MONTHLY) @map("billing_cycle")
  currency              String @default("INR")

  // Feature Toggles
  includedFeatures      Json   @default("[]") @map("included_features")
  excludedFeatures      Json   @default("[]") @map("excluded_features")

  // Trial & Grace
  gracePeriodDays       Int    @default(7) @map("grace_period_days")
  trialDays             Int    @default(14) @map("trial_days")

  // Overage
  allowOverage          Boolean @default(false) @map("allow_overage")
  overagePricePerUser   Float?  @map("overage_price_per_user")
  overagePricePerGB     Float?  @map("overage_price_per_gb")
  overageSessionPrice   Float?  @map("overage_session_price")

  isActive        Boolean  @default(true) @map("is_active")
  isPublic        Boolean  @default(true) @map("is_public")
  displayOrder    Int      @default(0) @map("display_order")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenantLicenses  TenantLicense[]

  @@map("license_plans")
}

model TenantLicense {
  id              String   @id @default(uuid())
  tenantId        String   @unique @map("tenant_id")
  planId          String   @map("plan_id")
  // Keep licensePlanId as alias for backward compat
  licensePlanId   String?  @map("license_plan_id")
  billingCycle    String   @default("monthly") @map("billing_cycle")
  startDate       DateTime @default(now()) @map("start_date")
  endDate         DateTime @default(now()) @map("end_date")
  autoRenew       Boolean  @default(true) @map("auto_renew")
  status          String   @default("active")
  paymentMethod   String?  @map("payment_method")
  lastPaymentDate DateTime? @map("last_payment_date")
  nextBillingDate DateTime? @map("next_billing_date")

  // Custom overrides
  customMaxUsers          Int?    @map("custom_max_users")
  customMaxSessions       Int?    @map("custom_max_sessions")
  customMaxSessionsPerUser Int?   @map("custom_max_sessions_per_user")
  customMaxDataGB         Float?  @map("custom_max_data_gb")
  customMaxVoters         Int?    @map("custom_max_voters")
  customMaxElections      Int?    @map("custom_max_elections")
  customMaxConstituencies Int?    @map("custom_max_constituencies")
  customMaxStorageMB      Int?    @map("custom_max_storage_mb")
  customMaxApiPerDay      Int?    @map("custom_max_api_per_day")
  customMaxApiPerHour     Int?    @map("custom_max_api_per_hour")
  customBasePrice         Float?  @map("custom_base_price")
  discountPercent         Float   @default(0) @map("discount_percent")

  // Dates
  activatedAt     DateTime? @map("activated_at")
  expiresAt       DateTime? @map("expires_at")
  trialEndsAt     DateTime? @map("trial_ends_at")
  suspendedAt     DateTime? @map("suspended_at")
  suspendedReason String?   @map("suspended_reason")
  cancelledAt     DateTime? @map("cancelled_at")

  // Enforcement
  enforceSessionLimit Boolean @default(true) @map("enforce_session_limit")
  enforceUserLimit    Boolean @default(true) @map("enforce_user_limit")
  enforceDataLimit    Boolean @default(true) @map("enforce_data_limit")
  enforceApiLimit     Boolean @default(true) @map("enforce_api_limit")
  softLimitMode       Boolean @default(false) @map("soft_limit_mode")

  // Admin
  adminNotes      String?  @map("admin_notes")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            LicensePlan @relation(fields: [planId], references: [id])
  sessions        TenantSession[]
  usageMetrics    TenantUsageMetrics[]
  usageAlerts     UsageAlert[]
  billingHistory  BillingHistory[]

  @@map("tenant_licenses")
}

model TenantSession {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  tenantLicenseId String?  @map("tenant_license_id")
  userId          String   @map("user_id")
  sessionToken    String   @unique @map("session_token")
  deviceInfo      Json?    @map("device_info")
  ipAddress       String?  @map("ip_address")
  isActive        Boolean  @default(true) @map("is_active")
  lastActivityAt  DateTime @default(now()) @map("last_activity_at")
  expiresAt       DateTime @map("expires_at")
  terminatedAt    DateTime? @map("terminated_at")
  terminationReason String? @map("termination_reason")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  license         TenantLicense? @relation(fields: [tenantLicenseId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([tenantLicenseId])
  @@map("tenant_sessions")
}

model TenantUsageMetrics {
  id                    String   @id @default(uuid())
  tenantLicenseId       String   @map("tenant_license_id")
  metricDate            DateTime @map("metric_date")
  metricHour            Int?     @map("metric_hour")
  activeUsers           Int      @default(0) @map("active_users")
  peakConcurrentSessions Int     @default(0) @map("peak_concurrent_sessions")
  apiRequestCount       Int      @default(0) @map("api_request_count")
  dataProcessedMB       Float    @default(0) @map("data_processed_mb")
  computedCost          Float    @default(0) @map("computed_cost")
  createdAt             DateTime @default(now()) @map("created_at")

  license               TenantLicense @relation(fields: [tenantLicenseId], references: [id])

  @@index([tenantLicenseId, metricDate])
  @@map("tenant_usage_metrics")
}

model UsageAlert {
  id              String   @id @default(uuid())
  tenantLicenseId String   @map("tenant_license_id")
  alertLevel      UsageAlertLevel @map("alert_level")
  alertType       String   @map("alert_type")
  message         String
  currentValue    Float?   @map("current_value")
  thresholdValue  Float?   @map("threshold_value")
  isRead          Boolean  @default(false) @map("is_read")
  isDismissed     Boolean  @default(false) @map("is_dismissed")
  isResolved      Boolean  @default(false) @map("is_resolved")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime @default(now()) @map("created_at")

  license         TenantLicense @relation(fields: [tenantLicenseId], references: [id])

  @@index([tenantLicenseId])
  @@map("usage_alerts")
}

model BillingHistory {
  id                  String   @id @default(uuid())
  tenantLicenseId     String   @map("tenant_license_id")
  invoiceNumber       String   @unique @map("invoice_number")
  billingPeriodStart  DateTime @map("billing_period_start")
  billingPeriodEnd    DateTime @map("billing_period_end")
  baseAmount          Float    @default(0) @map("base_amount")
  userOverageAmount   Float    @default(0) @map("user_overage_amount")
  sessionOverageAmount Float   @default(0) @map("session_overage_amount")
  dataOverageAmount   Float    @default(0) @map("data_overage_amount")
  discountAmount      Float    @default(0) @map("discount_amount")
  taxAmount           Float    @default(0) @map("tax_amount")
  totalAmount         Float    @default(0) @map("total_amount")
  paymentStatus       String   @default("pending") @map("payment_status")
  paymentMethod       String?  @map("payment_method")
  paymentReference    String?  @map("payment_reference")
  paidAt              DateTime? @map("paid_at")
  usageSummary        Json?    @map("usage_summary")
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  license             TenantLicense @relation(fields: [tenantLicenseId], references: [id])

  @@index([tenantLicenseId])
  @@map("billing_history")
}

// ==================== INVITATIONS (Cross-tenant) ====================

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
  RESENT
}

enum InvitationType {
  TENANT_ADMIN
  TENANT_USER
}

enum UserRole {
  SUPER_ADMIN
  CENTRAL_ADMIN
}

model Invitation {
  id                String           @id @default(uuid())
  invitationType    InvitationType   @map("invitation_type")

  tenantId          String?          @map("tenant_id")
  invitedByTenantId String?          @map("invited_by_tenant_id")
  electionId        String?          @map("election_id")

  email             String?
  mobile            String
  firstName         String           @map("first_name")
  lastName          String?          @map("last_name")
  role              UserRole

  token             String           @unique
  status            InvitationStatus @default(PENDING)
  message           String?

  invitedBy         String           @map("invited_by")
  invitedByName     String?          @map("invited_by_name")
  invitedByType     String           @map("invited_by_type")

  expiresAt         DateTime         @map("expires_at")
  acceptedAt        DateTime?        @map("accepted_at")
  cancelledAt       DateTime?        @map("cancelled_at")
  lastResentAt      DateTime?        @map("last_resent_at")
  resentCount       Int              @default(0) @map("resent_count")

  createdUserId     String?          @map("created_user_id")

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([mobile])
  @@index([email])
  @@index([token])
  @@index([status])
  @@map("invitations")
}

// ==================== AI CONFIGURATION (Global) ====================

model AIProvider {
  id              String   @id @default(uuid())
  providerName    String   @unique @map("provider_name")
  providerType    AIProviderType @default(CUSTOM) @map("provider_type")
  displayName     String?  @map("display_name")
  description     String?
  apiEndpoint     String?  @map("api_endpoint")
  apiKey          String?  @map("api_key")
  apiVersion      String?  @map("api_version")
  organizationId  String?  @map("organization_id")
  region          String?
  defaultModel    String?  @map("default_model")
  availableModels Json     @default("[]") @map("available_models")
  models          Json     @default("[]")

  // Rate limits
  maxRequestsPerMinute Int  @default(60) @map("max_requests_per_minute")
  maxTokensPerRequest  Int  @default(4096) @map("max_tokens_per_request")
  rateLimits      Json?    @map("rate_limits")

  // Cost
  costPerToken    Decimal? @map("cost_per_token") @db.Decimal(10, 8)
  costPerInputToken  Float @default(0) @map("cost_per_input_token")
  costPerOutputToken Float @default(0) @map("cost_per_output_token")
  costPerImage    Float    @default(0) @map("cost_per_image")
  costPerPage     Float    @default(0) @map("cost_per_page")
  currency        String   @default("USD")

  // Status
  status          AIProviderStatus @default(INACTIVE)
  lastHealthCheck DateTime? @map("last_health_check")
  lastError       String?  @map("last_error")
  errorCount      Int      @default(0) @map("error_count")
  successRate     Float    @default(0) @map("success_rate")

  // Capabilities
  supportsVision    Boolean @default(false) @map("supports_vision")
  supportsStreaming  Boolean @default(false) @map("supports_streaming")
  supportsAsync     Boolean @default(false) @map("supports_async")
  isDefault         Boolean @default(false) @map("is_default")

  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  features        AIFeature[]
  usageLogs       AIUsageLog[]

  @@map("ai_providers")
}

model AIFeature {
  id              String   @id @default(uuid())
  featureKey      String   @unique @map("feature_key")
  featureName     String   @map("feature_name")
  displayName     String?  @map("display_name")
  description     String?
  providerId      String   @map("provider_id")
  modelName       String?  @map("model_name")
  category        String?

  // Status
  status          AIFeatureStatus @default(DRAFT)

  // Prompts
  systemPrompt        String? @map("system_prompt")
  userPromptTemplate  String? @map("user_prompt_template")
  outputFormat        String? @map("output_format")
  outputSchema        Json?   @map("output_schema")

  // Input Configuration
  acceptedFileTypes   Json    @default("[]") @map("accepted_file_types")
  maxFileSize         Float   @default(10) @map("max_file_size")
  maxPagesPerRequest  Int     @default(50) @map("max_pages_per_request")

  // Credits/Pricing
  creditsPerUse   Int      @default(1) @map("credits_per_use")
  creditsPerPage  Float    @default(1) @map("credits_per_page")
  creditsPerImage Float    @default(1) @map("credits_per_image")
  creditsPerRequest Float  @default(0) @map("credits_per_request")
  minCreditsRequired Float @default(1) @map("min_credits_required")

  // Training
  isCustomTrained Boolean @default(false) @map("is_custom_trained")
  trainingData    Json?   @map("training_data")
  trainingNotes   String? @map("training_notes")

  // Availability
  isAddon         Boolean @default(true) @map("is_addon")
  isPublic        Boolean @default(false) @map("is_public")
  displayOrder    Int     @default(0) @map("display_order")
  iconUrl         String? @map("icon_url")

  // Dates
  publishedAt     DateTime? @map("published_at")
  deprecatedAt    DateTime? @map("deprecated_at")

  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  provider        AIProvider @relation(fields: [providerId], references: [id])
  subscriptions   TenantAISubscription[]
  usageLogs       AIUsageLog[]

  @@map("ai_features")
}

model AICreditPackage {
  id              String   @id @default(uuid())
  packageName     String   @unique @map("package_name")
  displayName     String?  @map("display_name")
  description     String?
  credits         Int
  price           Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  bonusCredits    Int      @default(0) @map("bonus_credits")
  validityDays    Int      @default(365) @map("validity_days")
  discountPercent Float    @default(0) @map("discount_percent")
  isPopular       Boolean  @default(false) @map("is_popular")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  transactions    AICreditTransaction[]

  @@map("ai_credit_packages")
}

model TenantAICredits {
  id                    String   @id @default(uuid())
  tenantId              String   @unique @map("tenant_id")
  balance               Int      @default(0)
  totalPurchased        Int      @default(0) @map("total_purchased")
  totalUsed             Int      @default(0) @map("total_used")
  lifetimeCredits       Int      @default(0) @map("lifetime_credits")
  lowBalanceAlert       Int      @default(100) @map("low_balance_alert")
  autoRechargeEnabled   Boolean  @default(false) @map("auto_recharge_enabled")
  autoRechargeThreshold Int      @default(50) @map("auto_recharge_threshold")
  autoRechargeAmount    Int      @default(0) @map("auto_recharge_amount")
  monthlyLimit          Int      @default(0) @map("monthly_limit")
  lastPurchaseAt        DateTime? @map("last_purchase_at")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_ai_credits")
}

model AICreditTransaction {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  transactionType   String   @map("transaction_type")
  creditsAmount     Int      @map("credits_amount")
  creditsBalance    Int      @default(0) @map("credits_balance")
  packageId         String?  @map("package_id")
  paymentReference  String?  @map("payment_reference")
  paymentAmount     Float?   @map("payment_amount")
  paymentCurrency   String   @default("USD") @map("payment_currency")
  notes             String?
  expiresAt         DateTime? @map("expires_at")
  processedBy       String?  @map("processed_by")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  package           AICreditPackage? @relation(fields: [packageId], references: [id])

  @@index([tenantId])
  @@map("ai_credit_transactions")
}

model TenantAISubscription {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  featureId           String   @map("feature_id")
  isEnabled           Boolean  @default(true) @map("is_enabled")
  customCreditsPerUse Float?   @map("custom_credits_per_use")
  customCreditsPerPage Float?  @map("custom_credits_per_page")
  expiresAt           DateTime? @map("expires_at")
  maxUsagePerDay      Int?     @map("max_usage_per_day")
  maxUsagePerMonth    Int?     @map("max_usage_per_month")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature             AIFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureId])
  @@map("tenant_ai_subscriptions")
}

model AIUsageLog {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  featureId       String   @map("feature_id")
  providerId      String   @map("provider_id")
  userId          String?  @map("user_id")
  inputTokens     Int      @default(0) @map("input_tokens")
  outputTokens    Int      @default(0) @map("output_tokens")
  totalCost       Float    @default(0) @map("total_cost")
  creditsUsed     Int      @default(0) @map("credits_used")
  processingTimeMs Int     @default(0) @map("processing_time_ms")
  status          String   @default("success")
  errorMessage    String?  @map("error_message")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature         AIFeature  @relation(fields: [featureId], references: [id])
  provider        AIProvider @relation(fields: [providerId], references: [id])

  @@index([tenantId])
  @@index([featureId])
  @@index([providerId])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

// ==================== WEBSITE TEMPLATES (Global) ====================

enum WebsiteTemplateType {
  POLITICAL_PARTY
  INDIVIDUAL_CANDIDATE
  CAMPAIGN
  NEWS_PORTAL
  ELECTION_COMMISSION
}

model WebsiteTemplate {
  id              String              @id @default(uuid())
  templateName    String              @map("template_name")
  templateCode    String              @unique @map("template_code")
  templateType    WebsiteTemplateType @map("template_type")
  description     String?
  thumbnailUrl    String?             @map("thumbnail_url")
  previewUrl      String?             @map("preview_url")
  colorSchemes    Json                @default("[]") @map("color_schemes")
  defaultSections Json                @default("[]") @map("default_sections")
  defaultConfig   Json                @default("{}") @map("default_config")
  isPremium       Boolean             @default(false) @map("is_premium")
  isActive        Boolean             @default(true) @map("is_active")
  sortOrder       Int                 @default(0) @map("sort_order")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@map("website_templates")
}

// ==================== EC INTEGRATION CONFIG (Global) ====================

model ECIntegrationConfig {
  id              String   @id @default(uuid())
  configKey       String   @unique @map("config_key")
  state           String?
  apiEndpoint     String?  @map("api_endpoint")
  apiKey          String?  @map("api_key")
  apiSecret       String?  @map("api_secret")
  authMethod      String?  @map("auth_method")
  settings        Json?
  syncIntervalHours Int    @default(24) @map("sync_interval_hours")
  autoSyncEnabled Boolean  @default(false) @map("auto_sync_enabled")
  nextSyncAt      DateTime? @map("next_sync_at")
  syncStatus      String?  @map("sync_status")
  isActive        Boolean  @default(true) @map("is_active")
  lastTestedAt    DateTime? @map("last_tested_at")
  lastError       String?  @map("last_error")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  syncLogs        ECSyncLog[]

  @@map("ec_integration_configs")
}

model ECSyncLog {
  id              String   @id @default(uuid())
  integrationId   String   @map("integration_id")
  syncType        String   @map("sync_type")
  status          String
  recordsProcessed Int     @default(0) @map("records_processed")
  recordsFailed   Int      @default(0) @map("records_failed")
  errorMessage    String?  @map("error_message")
  metadata        Json?
  startedAt       DateTime @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  integration     ECIntegrationConfig @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@map("ec_sync_logs")
}

// ==================== NEWS & ACTIONS ====================

model NewsInformation {
  id              String    @id @default(uuid())
  title           String
  titleLocal      String?   @map("title_local")
  content         String
  summary         String?
  category        String?
  subCategory     String?   @map("sub_category")
  tags            Json      @default("[]")
  imageUrl        String?   @map("image_url")
  imageUrls       Json      @default("[]") @map("image_urls")
  sourceUrl       String?   @map("source_url")
  sourceName      String?   @map("source_name")
  source          String?
  author          String?
  publishedAt     DateTime? @map("published_at")
  priority        String    @default("MEDIUM")
  // Geo scope
  scope           String    @default("national")
  geographicLevel String    @default("NATIONAL") @map("geographic_level")
  state           String?
  district        String?
  constituency    String?
  tenantId        String?   @map("tenant_id")
  // Status
  status          String    @default("draft")
  isActive        Boolean   @default(true) @map("is_active")
  isPinned        Boolean   @default(false) @map("is_pinned")
  viewCount       Int       @default(0) @map("view_count")
  // AI analysis
  aiAnalysis      Json?     @map("ai_analysis")
  sentimentScore  Float?    @map("sentiment_score")
  impactScore     Float?    @map("impact_score")
  relevanceScore  Float?    @map("relevance_score")
  suggestedActions Json?    @map("suggested_actions")
  analyzedAt      DateTime? @map("analyzed_at")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  actions         ActionItem[]

  @@index([tenantId])
  @@index([status])
  @@index([scope])
  @@index([geographicLevel])
  @@map("news_information")
}

model ActionItem {
  id                String    @id @default(uuid())
  title             String
  titleLocal        String?   @map("title_local")
  description       String?
  descriptionLocal  String?   @map("description_local")
  actionType        String    @map("action_type")
  priority          String    @default("MEDIUM")
  status            String    @default("pending")
  dueDate           DateTime? @map("due_date")
  assignedTo        String?   @map("assigned_to")
  assignedToName    String?   @map("assigned_to_name")
  assignedAt        DateTime? @map("assigned_at")
  tenantId          String?   @map("tenant_id")
  newsId            String?   @map("news_id")
  metadata          Json?
  aiGenerated       Boolean   @default(false) @map("ai_generated")
  // Geographic scope
  geographicLevel   String    @default("CONSTITUENCY") @map("geographic_level")
  state             String?
  region            String?
  district          String?
  constituency      String?
  section           String?
  booth             String?
  // Impact & tracking
  estimatedImpact   String?   @map("estimated_impact")
  requiredResources String?   @map("required_resources")
  targetAudience    String?   @map("target_audience")
  successMetrics    String?   @map("success_metrics")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  completionNotes   String?   @map("completion_notes")
  outcome           String?
  createdBy         String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant            Tenant?   @relation(fields: [tenantId], references: [id])
  news              NewsInformation? @relation(fields: [newsId], references: [id])

  @@index([tenantId])
  @@index([newsId])
  @@index([status])
  @@map("action_items")
}

// ==================== AUDIT & MONITORING (Core) ====================

model PlatformAuditLog {
  id              String   @id @default(uuid())
  actorId         String   @map("actor_id")
  actorType       String   @map("actor_type")
  action          String
  entityType      String   @map("entity_type")
  entityId        String?  @map("entity_id")
  tenantId        String?  @map("tenant_id")
  metadata        Json?
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("platform_audit_logs")
}

model AIAdminAlert {
  id              String   @id @default(uuid())
  alertType       String   @map("alert_type")
  severity        String   @default("info")
  title           String
  message         String
  tenantId        String?  @map("tenant_id")
  metadata        Json?
  isRead          Boolean  @default(false) @map("is_read")
  isResolved      Boolean  @default(false) @map("is_resolved")
  readAt          DateTime? @map("read_at")
  readBy          String?  @map("read_by")
  resolvedAt      DateTime? @map("resolved_at")
  resolvedBy      String?  @map("resolved_by")
  resolutionNotes String?  @map("resolution_notes")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant          Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([alertType])
  @@index([severity])
  @@index([tenantId])
  @@index([isRead])
  @@index([isResolved])
  @@map("ai_admin_alerts")
}
