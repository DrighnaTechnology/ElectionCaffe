// ==================== CAMPAIGNS & MESSAGING ====================

enum CampaignType {
  SMS
  WHATSAPP
  EMAIL
  VOICE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum MessagingProviderType {
  TWILIO
  MSG91
  GUPSHUP
  SENDGRID
  NODEMAILER
  CUSTOM
}

model Campaign {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  electionId      String         @map("election_id")
  campaignName    String         @map("campaign_name")
  campaignType    CampaignType   @map("campaign_type")
  message         String
  subject         String?
  mediaUrl        String?        @map("media_url")
  targetAudience  Json           @default("{}") @map("target_audience")
  targetCount     Int            @default(0) @map("target_count")
  status          CampaignStatus @default(DRAFT)
  scheduledAt     DateTime?      @map("scheduled_at")
  startedAt       DateTime?      @map("started_at")
  completedAt     DateTime?      @map("completed_at")
  sentCount       Int            @default(0) @map("sent_count")
  deliveredCount  Int            @default(0) @map("delivered_count")
  failedCount     Int            @default(0) @map("failed_count")
  readCount       Int            @default(0) @map("read_count")
  createdBy       String?        @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  election        Election       @relation(fields: [electionId], references: [id], onDelete: Cascade)
  messages        CampaignMessage[]

  @@index([tenantId])
  @@index([electionId])
  @@index([status])
  @@map("campaigns")
}

model CampaignMessage {
  id                String        @id @default(uuid())
  campaignId        String        @map("campaign_id")
  voterId           String?       @map("voter_id")
  voterName         String?       @map("voter_name")
  phone             String?
  email             String?
  channel           CampaignType
  status            MessageStatus @default(QUEUED)
  providerMessageId String?       @map("provider_message_id")
  errorMessage      String?       @map("error_message")
  sentAt            DateTime?     @map("sent_at")
  deliveredAt       DateTime?     @map("delivered_at")
  readAt            DateTime?     @map("read_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  campaign          Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([voterId])
  @@index([status])
  @@map("campaign_messages")
}

model MessagingProvider {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  channel         CampaignType
  provider        MessagingProviderType
  providerName    String?              @map("provider_name")
  config          Json                 @default("{}")
  isActive        Boolean              @default(true) @map("is_active")
  isDefault       Boolean              @default(false) @map("is_default")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([channel])
  @@index([tenantId, channel])
  @@map("messaging_providers")
}

