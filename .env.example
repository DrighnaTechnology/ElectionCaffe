# ElectionCaffe Environment Configuration

# ── Database ──────────────────────────────────────────────────────────────────
# Core database (super admin, tenants, plans, feature flags)
CORE_DATABASE_URL="postgresql://postgres:admin@localhost:5333/electioncaffecore?schema=public"
# Default tenant database (demo tenant)
TENANT_DATABASE_URL="postgresql://postgres:admin@localhost:5333/ec_demo?schema=public"
# Legacy (kept for backwards compatibility — points to core)
DATABASE_URL="postgresql://postgres:admin@localhost:5333/electioncaffe?schema=public"

# ── JWT Secrets (CHANGE THESE IN PRODUCTION!) ─────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production-min-32-chars"

# ── Service Ports ─────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_PORT=3001
ELECTION_PORT=3002
VOTER_PORT=3003
CADRE_PORT=3004
ANALYTICS_PORT=3005
REPORTING_PORT=3006
AI_ANALYTICS_PORT=3007
SUPER_ADMIN_PORT=3008
WEB_PORT=5173

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost,http://localhost:80,http://localhost:5000,http://localhost:5173,http://localhost:5174,http://localhost:8080"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
ENABLE_FILE_LOGGING="false"
LOG_DIR=""

# ── Security ──────────────────────────────────────────────────────────────────
# Credit Signature Secret (HMAC key for tamper detection on tenant AI credits)
CREDIT_SIGNATURE_SECRET="ec-credit-hmac-secret-change-in-production-min-32-chars"
# Internal Service-to-Service API Key
INTERNAL_API_KEY="ec-internal-api-key-change-in-production-min-32-chars"

# ── DataCaffe.ai Integration ─────────────────────────────────────────────────
DATACAFFE_API_URL="https://api.datacaffe.ai"
DATACAFFE_API_KEY=""

# ── File Storage (optional — for production use S3) ──────────────────────────
STORAGE_TYPE="local"
STORAGE_PATH="./uploads"

# ── AWS S3 (optional) ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""

# ── Redis (optional — for caching) ───────────────────────────────────────────
REDIS_URL=""

# ── AI Services (optional) ───────────────────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# ── Payment Gateway (optional) ───────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ── Tenant Configuration (production only) ───────────────────────────────────
# APP_DOMAIN="electioncaffe.com"

# ── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV="development"
