# =============================================================================
# ElectionCaffe - Production Environment Variables
# Copy to .env and update ALL values before deployment:
#   cp .env.production.example .env
#   nano .env
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
# Core database (tenants, super-admin, plans)
POSTGRES_USER=electioncaffe
POSTGRES_PASSWORD=<CHANGE-ME-strong-password>
POSTGRES_DB=electioncaffe_core

# Connection URLs (update host, port, password)
# For DigitalOcean managed DB: host=db-xxx.ondigitalocean.com, port=25060, sslmode=require
# For local PostgreSQL: host=localhost, port=5432
DATABASE_URL=postgresql://electioncaffe:<PASSWORD>@<DB_HOST>:<DB_PORT>/heliumdb?sslmode=require
CORE_DATABASE_URL=postgresql://electioncaffe:<PASSWORD>@<DB_HOST>:<DB_PORT>/electioncaffe_core?sslmode=require

# ── Authentication ───────────────────────────────────────────────────────────
# CRITICAL: Generate 64-char random strings. Must be unique and secret.
#   openssl rand -hex 32
JWT_SECRET=<CHANGE-ME-generate-64-char-random-string>
JWT_REFRESH_SECRET=<CHANGE-ME-generate-64-char-random-string>

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (include all domains + subdomains)
CORS_ORIGIN=https://election.datacaffe.ai,https://admin.election.datacaffe.ai

# ── Service Ports ────────────────────────────────────────────────────────────
# These match ecosystem.config.cjs — do not change unless you update both
GATEWAY_PORT=3000
AUTH_PORT=3001
ELECTION_PORT=3002
VOTER_PORT=3003
CADRE_PORT=3004
ANALYTICS_PORT=3005
REPORTING_PORT=3006
AI_ANALYTICS_PORT=3007
SUPER_ADMIN_PORT=3008

# ── Tenant Configuration ────────────────────────────────────────────────────
# Domain for tenant subdomains (e.g. <slug>.election.datacaffe.ai)
APP_DOMAIN=election.datacaffe.ai

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/var/www/electioncaffe/logs
ENABLE_FILE_LOGGING=true
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────────────────────
# HMAC key for tamper detection on tenant AI credits
CREDIT_SIGNATURE_SECRET=<CHANGE-ME-generate-strong-random-secret>

# ── DataCaffe.ai Integration ────────────────────────────────────────────────
DATACAFFE_API_URL=https://api.datacaffe.ai
DATACAFFE_API_KEY=

# ── AI Services (optional) ──────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── File Storage ─────────────────────────────────────────────────────────────
# Use "local" for VM storage, "s3" for AWS S3
STORAGE_TYPE=local
STORAGE_PATH=/var/www/electioncaffe/uploads

# AWS S3 (required if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# ── Redis (optional — for caching) ──────────────────────────────────────────
REDIS_URL=

# ── Email (optional — for notifications) ────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
